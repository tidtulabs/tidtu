{
	"name": "my-turborepo",
	"private": true,
	"scripts": {
		"build": "turbo build",
		"dev": "pnpm dev:stop && turbo dev",
		"dev:remote": "pnpm dev:stop && turbo dev:remote",
		"dev:stop": "npx kill-port 5173 3000 3001 4001 4002 4003",
		"lint": "turbo lint",
		"format": "prettier --write \"**/*.{ts,tsx,md}\""
	},
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"devDependencies": {
		"prettier": "^3.2.5",
		"turbo": "^2.3.3",
		"typescript": "5.5.4",
		"wrangler": "^4.110.0"
	},
	"packageManager": "pnpm@9.0.0",
	"engines": {
		"node": ">=18"
	}
}