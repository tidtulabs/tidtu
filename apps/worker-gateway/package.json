{
	"name": "worker-gateway",
	"scripts": {
		"dev": "wait-on tcp:4001 tcp:4002 tcp:4003 && wrangler dev --port 3001 --ip 0.0.0.0",
		"dev:remote": "wrangler dev --port 3001 --ip 0.0.0.0 --remote",
		"deploy": "wrangler deploy --minify",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"hono": "^4.6.15"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260714.1",
		"typescript": "^5.7.2",
		"wait-on": "^9.0.10",
		"wrangler": "^4.110.0"
	}
}